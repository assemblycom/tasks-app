{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["iad1", "pdx1"],
  "buildCommand": "./scripts/build.sh",
  "crons": [
    {
      "path": "/api/workers/scrap-medias",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "src/app/api/**/*": {
      "maxDuration": 300
    },
    "src/app/**/page.tsx": {
      "maxDuration": 60
    }
  }
}
